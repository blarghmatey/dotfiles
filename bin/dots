#!/usr/bin/env python3
"""Thin entry point — allows running dots directly from the repo without installation.

Usage (from repo root):
    ./bin/dots --help
    ./bin/dots sync --dry-run

Or after `uvenv install -e .`:
    dots --help
"""

from __future__ import annotations

import sys
from pathlib import Path

# Ensure the repo root is on the path when running directly (before installation)
_repo_root = Path(__file__).resolve().parent.parent
if str(_repo_root) not in sys.path:
    sys.path.insert(0, str(_repo_root))

from dots.cli import app  # noqa: E402

if __name__ == "__main__":
    app()

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on the first day of the month"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update tree-sitter language grammar versions in Emacs init.el",
      "managerFilePatterns": ["home/.emacs.d/init.el"],
      "matchStrings": [
        "\"https://github\\.com/(?<depName>[^/\"]+/[^/\"]+)\" \"(?<currentValue>v?[0-9][^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "description": "Group all tree-sitter grammar updates into a single PR",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["home/.emacs.d/init.el"],
      "groupName": "tree-sitter grammars",
      "automerge": false
    },
    {
      "description": "Ignore the intentionally git-pinned pyinfra (tracking upstream until 3.8 ships on PyPI)",
      "matchPackageNames": ["pyinfra"],
      "enabled": false
    }
  ]
}
